#!/bin/bash

set -e

# source the common build functions
SCRIPT_DIR=$(dirname "$0")
source "${SCRIPT_DIR}/ios_build_functions.sh"

function setup ()
{
    # update_libssh2_ios links the per-slice libssl.a/libcrypto.a, so the
    # xcframeworks alone are not enough to skip a rebuild after a partial
    # clean.
    if [ -d "${INSTALL_PATH}/libssl.xcframework" -a \
       -d "${INSTALL_PATH}/libcrypto.xcframework" -a \
       -d "${INSTALL_PATH}/include/openssl" ] && slice_libraries_exist libssl.a libcrypto.a
    then
        echo "No update needed."
        exit 0
    fi

    LIBRARY_NAME="OpenSSL"
}

function build_ssl ()
{
    rm -rf "${ARCH_INSTALL_PATH}/openssl"
    cp -r "${ROOT_PATH}/External/openssl" "${ARCH_INSTALL_PATH}/openssl"
    pushd "${ARCH_INSTALL_PATH}/openssl" > /dev/null

    HOST="BSD-generic64"
    CONFIG="no-gost no-asm enable-ec_nistp_64_gcc_128"

    ./Configure ${HOST} ${CONFIG} --openssldir="${ARCH_INSTALL_PATH}" >> "${LOG}" 2>&1
    perl -i -pe "s|^CC= gcc|CC= ${CLANG} -target ${CLANG_TARGET} -arch ${ARCH} |g" Makefile >> "${LOG}" 2>&1
    perl -i -pe "s|^CFLAG= (.*)|CFLAG= -isysroot ${SDKROOT} \$1|g" Makefile >> "${LOG}" 2>&1
    make >> "${LOG}" 2>&1

    make install_sw >> "${LOG}" 2>&1
    popd > /dev/null

    rm -rf "${ARCH_INSTALL_PATH}/openssl"

    BUILT_CRYPTO_PATHS+=("${ARCH_INSTALL_PATH}/lib/libcrypto.a")
    BUILT_SSL_PATHS+=("${ARCH_INSTALL_PATH}/lib/libssl.a")
}

function create_xcframeworks ()
{
    echo "Copying headers"
    cp -r "${ARCH_INSTALL_PATH}/include/openssl" "${INSTALL_PATH}/include/"

    echo "Creating libcrypto.xcframework and libssl.xcframework..."

    create_xcframework libcrypto "${BUILT_CRYPTO_PATHS[@]}"
    create_xcframework libssl "${BUILT_SSL_PATHS[@]}"

    echo "Building done."
}

build_all_slices setup build_ssl create_xcframeworks
