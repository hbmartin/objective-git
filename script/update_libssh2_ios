#!/bin/bash

set -e

# source the common build functions
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
source "${SCRIPT_DIR}/ios_build_functions.sh"

function setup ()
{
    # update_libgit2_ios links the per-slice libssh2.a, so the xcframework
    # alone is not enough to skip a rebuild after a partial clean.
    if [ -d "${INSTALL_PATH}/libssh2.xcframework" ] && slice_libraries_exist libssh2.a
    then
        echo "No update needed."
        exit 0
    fi
    LIBRARY_NAME="libssh2"
}

function build_ssh2 ()
{
    rm -rf "${ARCH_INSTALL_PATH}/libssh2"
    mkdir -p "${ARCH_INSTALL_PATH}/libssh2"
    pushd "${ARCH_INSTALL_PATH}/libssh2" > /dev/null

    cmake \
        -DBUILD_SHARED_LIBS:BOOL=OFF \
        -DBUILD_EXAMPLES:BOOL=OFF \
        -DBUILD_TESTING:BOOL=OFF \
        -DCRYPTO_BACKEND:STRING=OpenSSL \
        -DOPENSSL_ROOT_DIR:PATH="${ARCH_INSTALL_PATH}" \
        -DOPENSSL_INCLUDE_DIR:PATH="${ARCH_INSTALL_PATH}/include" \
        -DOPENSSL_CRYPTO_LIBRARY:FILEPATH="${ARCH_INSTALL_PATH}/lib/libcrypto.a" \
        -DOPENSSL_SSL_LIBRARY:FILEPATH="${ARCH_INSTALL_PATH}/lib/libssl.a" \
        -DCMAKE_INSTALL_PREFIX:PATH="${ARCH_INSTALL_PATH}" \
        -DCMAKE_C_FLAGS:STRING="-target ${CLANG_TARGET}" \
        -DCMAKE_OSX_ARCHITECTURES:STRING="${ARCH}" \
        -DCMAKE_OSX_DEPLOYMENT_TARGET:STRING="${IPHONEOS_DEPLOYMENT_TARGET}" \
        -DCMAKE_OSX_SYSROOT:PATH="${SDKROOT}" \
        -DCMAKE_POLICY_VERSION_MINIMUM:STRING=3.5 \
        "${ROOT_PATH}/External/libssh2" >> "${LOG}" 2>&1
    cmake --build . --target install >> "${LOG}" 2>&1
    popd > /dev/null

    rm -rf "${ARCH_INSTALL_PATH}/libssh2"

    BUILT_LIBS+=("${ARCH_INSTALL_PATH}/lib/libssh2.a")
}

function create_xcframeworks ()
{
    echo "Copying headers"

    cp -r "${ARCH_INSTALL_PATH}"/include/libssh*.h "${INSTALL_PATH}/include/"

    echo "Creating libssh2.xcframework..."

    create_xcframework libssh2 "${BUILT_LIBS[@]}"

    echo "Building done."
}

build_all_slices setup build_ssh2 create_xcframeworks
